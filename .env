# Rename this file to .env before running the project

# Server
PORT=5000

# MongoDB connection string (local or Atlas)
MONGO_URI=mongodb://127.0.0.1:27017/leave_management_system

# JWT secret used to sign authentication tokens
JWT_SECRET=supersecret_leave_management_jwt_key_2024
JWT_EXPIRES_IN=1d

# Default admin account created by seed.js
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=Admin@123
